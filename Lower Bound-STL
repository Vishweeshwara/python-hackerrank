#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
int n;
    cin >> n;
    
    
    vector<int> v(n);
    for (int i = 0; i < n; i++) {
        cin >> v[i];
    }
    
    int q_count;
    cin >> q_count;
    
    
    for (int i = 0; i < q_count; i++) {
        int query_val;
        cin >> query_val;
        
        
        vector<int>::iterator it = lower_bound(v.begin(), v.end(), query_val);
        
        
        int index = (it - v.begin()) + 1;
        
        
        if (it != v.end() && *it == query_val) {
            cout << "Yes " << index << endl;
        } else {
            cout << "No " << index << endl;
        }
    }
    
    return 0;
}
