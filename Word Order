from collections import OrderedDict

# Read the number of words
n = int(input())

# Initialize an ordered dictionary to store word counts
word_counts = OrderedDict()

for _ in range(n):
    word = input().strip()
    # If the word exists, increment count; otherwise, initialize it to 1
    if word in word_counts:
        word_counts[word] += 1
    else:
        word_counts[word] = 1

# Output 1: Total number of distinct words
print(len(word_counts))

# Output 2: Occurrences of each word in order of appearance
# Using '*' unpacks the values and prints them space-separated
print(*(word_counts.values()))
